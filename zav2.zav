Expr(i32) = enum {
    Int(i32),
    Add(Self(i32), Self(i32)),
    If(XXXXXXX(bool), Self(i32), Self(i32)),
}

def Expr.eval = fn(self: Self(type[Add,Sub,Mul,Div]$T)) -> $T {
    match self {
        Self.Int(val) => val, // i32
        Self.Bool(val) => val, // bool
        Self.Float(val) => val, // f32
        Self.Vec(val) => val, // [(i32 | bool | f32)]
        Self.Add(lhs, rhs) => lhs.eval() + rhs.eval(), // i32
        Self.Eq(lhs, rhs) => lhs.eval() == rhs.eval(), // bool
        Self.If(condition, lhs, rhs) => if condition { lhs.eval() } else { rhs.eval() }, // (i32 | bool | f32 | [(i32 | bool | f32)])
    }
}

