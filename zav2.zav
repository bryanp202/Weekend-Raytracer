def Expr = enum(_: type, N: u64) {
    Int(i32) -> Self(i32, N),
    Bool(bool) -> Self(bool, N),
    Float(f32) -> Self(f32, N),
    Vec([$T; N]) -> Self([$T; N], N),
    Add(Self(i32), Self(i32)) -> Self(i32, N),
    Eq(Self($T[Eq]), Self($T[Eq])) -> Self(bool, N),
    If(Self(bool), Self($T), Self($T)) -> Self($T, N),
};

def ExprMaker = fn(n: u64) -> type {
    enum(type) {
        Int(i32)                            -> Self(i32),
        Bool(bool)                          -> Self(bool),
        Float(f32)                          -> Self(f32),
        Vec([$T; n])                        -> Self([$T; n]),
        Add(Self(i32), Self(i32))           -> Self(i32),
        Eq(Self($T[Eq]), Self($T))          -> Self(bool),
        If(Self(bool), Self($T), Self($T))  -> Self($T),
    }
}

