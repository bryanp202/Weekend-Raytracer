def eval = fn(expr: Expr($T: type)) -> $T {
    let result: $T = match expr {
        Expr.Int(val) => val,                           // Expr(i32)
        Expr.Add(lhs, rhs) => eval(lhs) + eval(rhs),    // Expr(i32)
        Expr.Bool(val) => val,                          // Expr(bool)
        Expr.Eq(lhs, rhs) => eval(lhs) == eval(rhs),    // Expr(bool)
    };

    std.debug.print("The result was {}!\n", result);

    result
}

