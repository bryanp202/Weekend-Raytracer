def sum = fn [N: $[1; Add[$1, Output=$1]]]
(nums: N) {
    let mut sum = nums[$0];
    $for num in nums {
        sum += num;
    }
    sum
}

def sum = fn [
    N: $[2; Add[$1, Output=$1]],
    P: $[1; Mul[N[$-1], Output=R]],
    R,
] (nums: N) {
    let mut sum = nums[$0];
    $for num in nums {
        sum += num;
    }
    sum
}

def sum = fn [
    N: $[2; Add[$1, Output=$1]],
    P: $[1; Mul[N[-1], Output=R]],
    R,
] (
    nums: N,
    prods: P,
    result: &mut R,
) -> () {
    let sum = $fold (curr, num) in nums {
        curr + num
    };

    *result = $fold (curr = sum, num) in prods {
        curr * num
    };
}

def main = fn() {
    let mut result;
    sum(
        $[1, 2, 2.4, 3, (1, 1), 0.001],
        $[1.2, 2, 2u8, 20i32],
        &mut result
    );
}

