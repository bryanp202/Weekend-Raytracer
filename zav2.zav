def Vec2(T: type[Add, Sub]) {
    def mut cool: i32 = 100;

    def new = fn(x: T, y: T) -> Self {
        Self { x, y }
    }

    def add = fn(self, other: Self) -> Self {
        self + other
    }

    def Add = impl Add {
        fn(self, other: Self) -> Self {
            Self {
                x: self.x + other.x,
                y: self.y + other.y,
            }
        }
    }
}

def main = fn(argc: i64, argv: **u8) -> i64 {
    let a = GVec2(Vec2, i32).new(Vec2.new(1i32, 2i32), Vec2.new(1i32, 2i32), 1i32);
    let b = .new(.new(2i32, 3i32), .new(3i32, 4i32), 1i32);
    let c = a.AddWeird.Add(b);

    std.io.stdout().print(c.display());

    let a = Vec2(i32)::new(1, 2);
    let b = ::new(3, 4);
    let c = a + b;
    let d = ::add(a, b);
    let e = ::Add.add(a, b);

    assert_eq!(c, d);
    assert_eq!(d, e);

    return 0;
}

def root = fn(num: i32) -> i32 {
    let kind: type(i32 | u32) = if num < 0 {
        i32
    } else {
        u32
    };

    let min: i32 | u32 = kind.MIN;
    std.math.root(kind, num + min).into(i32)
}

def root = fn(num: i32) -> i32 {
    if num < 0 {
        let min: i32 = i32.MIN;
        std.math.root(i32, num + min)//.into(i32) no op
    } else {
        let min: u32 = u32.MIN;
        std.math.root(i32, num + min).into(i32)
    }
}

