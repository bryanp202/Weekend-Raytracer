def GVec2 = fn(S: fn(type[Add, Sub])type[Add, Sub], T: type[Add, Sub]) -> type[Add, Sub] {
    struct {
        x: S(T),
        y: S(T),
        z: T,
    }
}

def GVec2(S: Vec2, T: i32).new = fn(x: S(T), y: S(T), z: T) -> Self {

}

def GVec2(
    S: fn(type[Add, Sub])type[Add, Sub],
    T: type[Add, Sub],
).new = fn(
    x: S(T),
    y: S(T),
    z: T,
) -> Self {
    Self { x, y, z }
}

def GVec2(
    S: fn(type[Add, Sub, Display]),
    T: type[Add, Sub, Display],
) {
    def new = fn(
        x: S(T),
        y: S(T),
        z: T,
    ) -> Self {
        Self { x, y, z }
    }

    def Add = impl Add {
        def add = fn(self, rhs) {
            Self {
                x: self.x + other.x,
                y: self.y + other.y,
                z: self.z + other.z,
            }
        }
    }

    def AddWeird = impl Add {
        def add = fn(self, rhs) {
            Self {
                x: self.x + other.y,
                x: self.y + other.x,
                z: self.z + other.z,
            }
        }
    }

    def Display = impl Display {
        def display = fn(&self) {
            std.fmt.format("x: {}, y: {}, z: {}", self.x, self.y, self.z)
        }
    }
}

